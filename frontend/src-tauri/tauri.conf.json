{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UIL-DL",
  "version": "2.0.0",
  "identifier": "dev.randeria.uildl",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:frontend",
    "beforeBuildCommand": "pnpm build:frontend"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'",
      "pattern": {
        "use": "isolation",
        "options": {
          "dir": "./isolation"
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../src/lib/icons/32x32.png",
      "../src/lib/icons/128x128.png",
      "../src/lib/icons/128x128@2x.png",
      "../src/lib/icons/icon.icns",
      "../src/lib/icons/icon.ico"
    ]
  }
}
