{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "uil-dl",
  "version": "0.1.0",
  "identifier": "dev.randeria.uildl",
  "build": {
    "frontendDist": "../public",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:frontend",
    "beforeBuildCommand": "pnpm build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "UIL-DL",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../src/lib/icons/32x32.png",
      "../src/lib/icons/128x128.png",
      "../src/lib/icons/128x128@2x.png",
      "../src/lib/icons/icon.icns",
      "../src/lib/icons/icon.ico"
    ]
  }
}
