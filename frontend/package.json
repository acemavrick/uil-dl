{
	"name": "uil-dl",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
	  "gen-icons": "rm -rf src/lib/icons && tauri icon -o src/lib/icons ../assets/app-icon.png && rm -rf src/lib/icons/ios src/lib/icons/android && echo 'Generated icons, deleted iOS & Android'",
		"dev:frontend": "vite dev",
		"build:frontend": "vite build",
		"dev": "pnpm tauri dev",
		"build": "pnpm tauri build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy:pages": "wrangler pages deploy ./build --project-name uil-dl-online --commit-dirty=true"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@tauri-apps/cli": "^2.9.6",
		"svelte": "^5.47.1",
		"svelte-check": "^4.3.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
